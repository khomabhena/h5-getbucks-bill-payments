# VAS server URL (BankWare merchant account is loaded from server at payment time)
VITE_API_BASE_URL=https://4.222.185.132.nip.io/vas
VITE_GETBUCKS_DEFAULT_CURRENCY=USD

# Optional dev fallback if /api/payment-config/merchant-account is unavailable
# VITE_GETBUCKS_MERCHANT_ACCOUNT=00001501
# Optional standalone testing
# VITE_SAMPLE_CUSTOMER_ACCOUNT=
# VITE_SAMPLE_CLIENT_NUMBER=
# VITE_GETBUCKS_IFS_PROGRAM_ID=

# BankWare value date (matches airtime H5)
# VITE_BANK_VALUE_DATE_TZ=Africa/Harare
# VITE_BANK_VALUE_DATE_UTC_OFFSET_HOURS=2
